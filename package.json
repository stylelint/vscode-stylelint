{
  "name": "vscode-stylelint",
  "version": "2.2.1",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "description": "Official Stylelint extension for Visual Studio Code",
  "main": "dist/index.js",
  "displayName": "Stylelint",
  "publisher": "stylelint",
  "repository": {
    "type": "git",
    "url": "https://github.com/stylelint/vscode-stylelint.git"
  },
  "homepage": "https://github.com/stylelint/vscode-stylelint#readme",
  "bugs": "https://github.com/stylelint/vscode-stylelint/issues",
  "qna": "https://stackoverflow.com/questions/tagged/vscode+stylelint",
  "sponsor": {
    "url": "https://opencollective.com/stylelint"
  },
  "icon": "media/stylelint.png",
  "engines": {
    "vscode": ">=1.103.0"
  },
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "categories": [
    "Linters",
    "Snippets",
    "Programming Languages"
  ],
  "keywords": [
    "css",
    "less",
    "sass",
    "scss",
    "sugarss",
    "lint",
    "linter",
    "style",
    "stylelint",
    "validation",
    "check"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Stylelint",
      "properties": {
        "stylelint.enable": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Control whether Stylelint is enabled or not."
        },
        "stylelint.run": {
          "scope": "resource",
          "type": "string",
          "enum": [
            "onSave",
            "onType"
          ],
          "default": "onType",
          "description": "Control when the extension lints your files. onType lints files as you edit them, while onSave only lints when you save the file."
        },
        "stylelint.logLevel": {
          "scope": "machine",
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Controls the log level used by the Stylelint extension and language server. Restart the extension host or the window after changing the setting, since it's picked up at initialization."
        },
        "stylelint.runtime": {
          "scope": "machine-overridable",
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "markdownDescription": "The location of the node binary to run Stylelint under."
        },
        "stylelint.execArgv": {
          "scope": "machine-overridable",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "markdownDescription": "Additional exec argv arguments passed to the Node.js runtime."
        },
        "stylelint.codeAction.disableRuleComment": {
          "scope": "resource",
          "type": "object",
          "default": {
            "location": "separateLine"
          },
          "properties": {
            "location": {
              "type": "string",
              "enum": [
                "separateLine",
                "sameLine"
              ],
              "default": "separateLine",
              "description": "Configure whether disable comments are added on the same line or a new line."
            }
          },
          "additionalProperties": false,
          "description": "Options for the disable lint rule action in the quick fix menu."
        },
        "stylelint.config": {
          "scope": "resource",
          "type": [
            "object",
            "null"
          ],
          "default": null,
          "description": "A Stylelint configuration object."
        },
        "stylelint.configFile": {
          "scope": "resource",
          "type": "string",
          "default": "",
          "description": "Path to a JSON, YAML, or JS file that contains your configuration object. Use this option if you don't want Stylelint to search for a configuration file."
        },
        "stylelint.configBasedir": {
          "scope": "resource",
          "type": "string",
          "default": "",
          "description": "A path to the directory that relative paths defining \"extends\" and \"plugins\" are relative to."
        },
        "stylelint.customSyntax": {
          "scope": "resource",
          "type": "string",
          "default": "",
          "description": "An absolute path to a custom PostCSS-compatible syntax module."
        },
        "stylelint.ignorePath": {
          "scope": "resource",
          "type": "string",
          "default": "",
          "description": "Path to a file containing patterns describing files to ignore. Use to override automatic `.stylelintignore` detection."
        },
        "stylelint.reportDescriptionlessDisables": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Report `stylelint-disable` comments without a description."
        },
        "stylelint.ignoreDisables": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Ignore `stylelint-disable` (e.g. `/* stylelint-disable block-no-empty */`) comments."
        },
        "stylelint.reportNeedlessDisables": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Also report errors for `stylelint-disable` comments that are not blocking a lint warning."
        },
        "stylelint.reportInvalidScopeDisables": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Also report errors for `stylelint-disable` comments that used for rules that don't exist within the configuration object."
        },
        "stylelint.stylelintPath": {
          "scope": "resource",
          "type": "string",
          "default": "",
          "description": "Supply a custom path to the Stylelint module."
        },
        "stylelint.packageManager": {
          "scope": "resource",
          "type": "string",
          "enum": [
            "npm",
            "yarn",
            "pnpm"
          ],
          "default": "npm",
          "description": "The package manager you use to install node modules."
        },
        "stylelint.validate": {
          "scope": "resource",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "css",
            "postcss"
          ],
          "description": "An array of language ids which should be validated by Stylelint."
        },
        "stylelint.snippet": {
          "scope": "resource",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "css",
            "postcss"
          ],
          "description": "An array of language ids which snippets are provided by Stylelint."
        },
        "stylelint.rules.customizations": {
          "scope": "resource",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule": {
                "type": "string",
                "description": "Rule name pattern to match. `*` is treated as a wildcard. Prefix with `!` to match all rules that do NOT match the pattern."
              },
              "severity": {
                "type": "string",
                "enum": [
                  "downgrade",
                  "upgrade",
                  "error",
                  "warn",
                  "info",
                  "off",
                  "default"
                ],
                "description": "Severity override: `downgrade` converts errors to warnings and warnings to info messages, `upgrade` converts warnings to errors, `default` uses the original severity from Stylelint, or specify exact severity."
              }
            },
            "required": [
              "rule",
              "severity"
            ],
            "additionalProperties": false
          },
          "default": [],
          "description": "Override severity levels for specific rules."
        },
        "stylelint.lintFiles.glob": {
          "scope": "resource",
          "type": "string",
          "default": "**/*.css",
          "description": "The glob pattern used by the \"Lint All Files\" and \"Lint Workspace Folder\" commands to discover files. Adjust this if you lint SCSS, Less, or other file types; for example, `**/*.{css,scss}`."
        }
      }
    },
    "commands": [
      {
        "title": "Fix all auto-fixable Problems",
        "category": "Stylelint",
        "command": "stylelint.executeAutofix"
      },
      {
        "title": "Lint All Files",
        "category": "Stylelint",
        "command": "stylelint.lintAllFiles"
      },
      {
        "title": "Lint Workspace Folder",
        "category": "Stylelint",
        "command": "stylelint.lintWorkspaceFolder"
      },
      {
        "title": "Clear All Problems",
        "category": "Stylelint",
        "command": "stylelint.clearAllProblems"
      },
      {
        "title": "Restart Stylelint Server",
        "category": "Stylelint",
        "command": "stylelint.restart"
      },
      {
        "title": "Show Output Channel",
        "category": "Stylelint",
        "command": "stylelint.showOutputChannel"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "**/.stylelintrc*",
        "url": "https://json.schemastore.org/stylelintrc.json"
      }
    ],
    "languages": [
      {
        "id": "ignore",
        "filenames": [
          ".stylelintignore"
        ]
      }
    ],
    "problemPatterns": [
      {
        "name": "stylelint-compact",
        "regexp": "^(.+): line (\\d+), col (\\d+), (\\w+) - (.*?)\\s\\(([^)]+)\\)\\s*$",
        "file": 1,
        "line": 2,
        "column": 3,
        "severity": 4,
        "message": 5,
        "code": 6
      },
      {
        "name": "stylelint-unix",
        "regexp": "^(.+):(\\d+):(\\d+): (.*?)\\s\\(([^)]+)\\) \\[(\\w+)\\]\\s*$",
        "file": 1,
        "line": 2,
        "column": 3,
        "message": 4,
        "code": 5,
        "severity": 6
      }
    ],
    "problemMatchers": [
      {
        "name": "stylelint-compact",
        "label": "Stylelint problems (compact formatter)",
        "owner": "Stylelint",
        "source": "Stylelint",
        "fileLocation": [
          "autoDetect",
          "${workspaceFolder}"
        ],
        "pattern": "$stylelint-compact"
      },
      {
        "name": "stylelint-unix",
        "label": "Stylelint problems (unix formatter)",
        "owner": "Stylelint",
        "source": "Stylelint",
        "fileLocation": [
          "autoDetect",
          "${workspaceFolder}"
        ],
        "pattern": "$stylelint-unix"
      }
    ]
  },
  "dependencies": {
    "@stylelint/language-server": "workspace:*",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@changesets/get-github-info": "^0.8.0",
    "@stylelint/prettier-config": "^4.0.0",
    "@types/node": "22.17.2",
    "@types/vscode": "1.103.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "cspell": "^9.7.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.1.0",
    "eslint-config-stylelint": "^27.0.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.10",
    "postcss-html": "^1.8.1",
    "postcss-markdown": "^1.3.1",
    "postcss-sass": "^0.5.0",
    "postcss-scss": "^4.0.9",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.3",
    "semver": "^7.7.4",
    "stylelint": "^17.6.0",
    "stylelint-scss": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "winston": "^3.19.0",
    "wireit": "^0.14.12"
  },
  "overrides": {
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.3"
    },
    "postcss-styled-syntax": {
      "typescript": "$typescript"
    },
    "vitest": {
      "vite": "^7.3.1"
    }
  },
  "scripts": {
    "build": "wireit",
    "build-bundle-watch": "run:p build-watch bundle-watch",
    "build-watch": "tsc -b tsconfig.src.json --watch",
    "bundle": "wireit",
    "bundle:minify": "wireit",
    "bundle-watch": "node --experimental-strip-types scripts/bundle.mts --sourcemap --watch",
    "build-bundle": "wireit",
    "format": "prettier . --write",
    "lint": "wireit",
    "lint:formatting": "wireit",
    "lint:js": "wireit",
    "lint:spelling": "wireit",
    "lint:types": "wireit",
    "lint:unit-tests": "wireit",
    "test": "wireit",
    "test:e2e": "node --experimental-strip-types scripts/run-e2e.mts",
    "test:integration": "wireit",
    "test:unit": "wireit",
    "test:node-versions": "node --experimental-strip-types scripts/test-node-versions.mts",
    "changeset": "node --experimental-strip-types .changeset/sync-extension-version.mts --seed && changeset version && node --experimental-strip-types .changeset/rewrite-changelog.mts packages/vscode-stylelint/CHANGELOG.md && node --experimental-strip-types .changeset/rewrite-changelog.mts packages/language-server/CHANGELOG.md && node --experimental-strip-types .changeset/sync-extension-version.mts --sync && npm install --ignore-scripts",
    "vscode:prepublish": "wireit",
    "vscode:launch": "node --experimental-strip-types scripts/launch-vscode.mts",
    "publish": "vsce publish --no-git-tag-version --no-update-package-json",
    "switch-stylelint": "node --experimental-strip-types scripts/switch-stylelint.mts"
  },
  "wireit": {
    "env": {
      "files": [
        "package.json",
        ".nvmrc",
        ".stylelint-version"
      ]
    },
    "build": {
      "command": "tsc -b tsconfig.src.json",
      "dependencies": [
        "env"
      ],
      "files": [
        "src/**/*.ts",
        "packages/language-server/src/**/*.ts",
        "packages/language-server/tsconfig.json",
        "tsconfig.src.json",
        "tsconfig.base.json"
      ],
      "output": [
        "build/**",
        "packages/language-server/build/**",
        "tsconfig.src.tsbuildinfo",
        "packages/language-server/tsconfig.tsbuildinfo"
      ],
      "clean": "if-file-deleted"
    },
    "bundle": {
      "command": "node --experimental-transform-types scripts/bundle.mts --sourcemap",
      "dependencies": [
        "build"
      ],
      "files": [
        "scripts/bundle.mts"
      ],
      "output": [
        "dist/**"
      ]
    },
    "bundle:minify": {
      "command": "node --experimental-transform-types scripts/bundle.mts --minify",
      "dependencies": [
        "build"
      ],
      "files": [
        "scripts/bundle.mts"
      ],
      "output": [
        "dist/**"
      ]
    },
    "build-bundle": {
      "dependencies": [
        "bundle"
      ]
    },
    "lint": {
      "dependencies": [
        "lint:formatting",
        "lint:js",
        "lint:spelling",
        "lint:types",
        "lint:unit-tests"
      ]
    },
    "lint:formatting": {
      "command": "prettier . --check",
      "dependencies": [
        "env"
      ],
      "files": [
        "**/*.{js,mjs,cjs,ts,mts,cts,json,md,yml,css,scss}",
        ".editorconfig",
        ".prettierignore"
      ],
      "output": []
    },
    "lint:js": {
      "command": "eslint --cache --concurrency=auto",
      "dependencies": [
        "env"
      ],
      "files": [
        "**/*.{js,mjs,cjs,ts,mts,cts}"
      ],
      "output": [
        ".eslintcache"
      ]
    },
    "lint:spelling": {
      "command": "cspell lint --no-progress",
      "dependencies": [
        "env"
      ],
      "files": [
        "**/*.{js,mjs,cjs,ts,mts,cts,json,md,yml,css,scss}"
      ],
      "output": []
    },
    "lint:types": {
      "command": "tsc -b",
      "dependencies": [
        "env"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "scripts/**",
        "packages/language-server/src/**/*.ts",
        "packages/language-server/tsconfig.json",
        "*.{js,mjs,mts}",
        ".*.js",
        "tsconfig*.json"
      ],
      "output": [
        "tsconfig.src.tsbuildinfo",
        "tsconfig.scripts.tsbuildinfo",
        "tsconfig.test.tsbuildinfo",
        "packages/language-server/tsconfig.tsbuildinfo"
      ],
      "clean": "if-file-deleted"
    },
    "lint:unit-tests": {
      "command": "node --experimental-transform-types scripts/enforce-unit-tests-per-file.mts",
      "dependencies": [
        "env"
      ],
      "files": [
        "src/**/*.ts",
        "packages/language-server/src/**/*.ts",
        "scripts/enforce-unit-tests-per-file.mts"
      ],
      "output": []
    },
    "test": {
      "command": "vitest run",
      "dependencies": [
        "build-bundle"
      ],
      "files": [
        "src/**",
        "packages/language-server/src/**",
        "test/**",
        "vitest.config.mts",
        "vitest.config.unit.mts",
        "vitest.config.integration.mts"
      ],
      "output": []
    },
    "test:integration": {
      "command": "vitest run --project integration",
      "dependencies": [
        "build-bundle"
      ],
      "files": [
        "src/**/*.ts",
        "packages/language-server/src/**/*.ts",
        "test/integration/**",
        "test/helpers/**",
        "test/shared/**",
        "vitest.config.mts",
        "vitest.config.integration.mts"
      ],
      "output": []
    },
    "test:unit": {
      "command": "vitest run --project unit",
      "dependencies": [
        "env"
      ],
      "files": [
        "src/**",
        "packages/language-server/src/**",
        "test/helpers/**",
        "test/*.ts",
        "vitest.config.mts",
        "vitest.config.unit.mts"
      ],
      "output": []
    },
    "vscode:prepublish": {
      "dependencies": [
        "bundle:minify"
      ]
    }
  },
  "prettier": "@stylelint/prettier-config",
  "volta": {
    "node": "22.17.0",
    "npm": "11.0.0"
  }
}
