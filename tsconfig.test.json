{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "es2022",
		"types": ["node", "semver", "vscode", "path-is-inside", "vitest/globals", "mocha"],
		"noEmit": true,
		"isolatedModules": true
	},
	"include": ["src/**/*", "test/**/*", "packages/language-server/src/**/*"],
	"exclude": ["**/coverage", "test/e2e/workspace"]
}
